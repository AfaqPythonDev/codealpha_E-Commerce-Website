{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "server/data/*.json"
        ]
      }
    }
  ],
  "functions": {
    "server.js": {
      "includeFiles": "server/data/*.json"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
